<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.InitialScanPromptWindow"
        Title="Initial Scan"
        Width="640"
        Height="720"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">
            <Grid>
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Title Bar -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Name="TxtTitle"
                                           Text="{DynamicResource TxtInitialScanTitle}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrTextPrimary}"/>
                                <TextBlock Name="TxtDesc"
                                           Text="{DynamicResource TxtInitialScanDesc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="24,20">

                                <!-- Refresh missing covers only -->
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        Margin="0,0,0,20">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource TxtRefreshCoversTitle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrTextPrimary}"/>
                                            <TextBlock Text="{DynamicResource TxtRefreshCoversDesc}"
                                                       Foreground="{StaticResource BrTextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,16,0"
                                                       FontSize="{StaticResource FontSizeCaption}"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      Name="TglRefreshCoversOnly"
                                                      OnContent="" OffContent=""
                                                      IsChecked="False"
                                                      IsCheckedChanged="TglRefreshCoversOnly_IsCheckedChanged"/>
                                    </Grid>
                                </Border>

                                <!-- Upscaler filter mode -->
                                <StackPanel Name="PnlUpscalerFilter" Spacing="8" Margin="0,0,0,20">

                                    <TextBlock Text="{DynamicResource TxtFilterOptions}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{StaticResource BrTextPrimary}"
                                               Margin="0,0,0,4"/>

                                    <!-- Option 1: Show All -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,10">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterShowAll"
                                                         GroupName="UpscalerFilterScan"
                                                         IsChecked="True"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{DynamicResource TxtFilterShowAllTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterShowAllDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Option 2: Hide without upscaler -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,10">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterHideWithoutUpscaler"
                                                         GroupName="UpscalerFilterScan"
                                                         IsChecked="False"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{DynamicResource TxtFilterHideTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterHideDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Option 3: Skip without upscaler -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,10">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterSkipWithoutUpscaler"
                                                         GroupName="UpscalerFilterScan"
                                                         IsChecked="False"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <TextBlock Text="{DynamicResource TxtFilterSkipTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterSkipDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,2,0,0"/>
                                                <Border Background="#1AF59E0B"
                                                        BorderBrush="#40F59E0B"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="10,7">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <TextBlock Grid.Column="0" Text="&#xE7BA;"
                                                                   FontFamily="{StaticResource FontIcons}"
                                                                   FontSize="13"
                                                                   Foreground="#F59E0B"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,1,8,0"/>
                                                        <TextBlock Grid.Column="1" Text="{DynamicResource TxtFilterSkipWarning}"
                                                                   Foreground="#F59E0B"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="{StaticResource FontSizeCaption}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                </StackPanel>

                                <!-- Scan options panel (disabled when covers-only is active) -->
                                <StackPanel Name="PnlScanOptions">

                                <TextBlock Text="{DynamicResource TxtInitialScanDrives}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>

                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        Margin="0,0,0,24">
                                    <StackPanel Name="PnlDriveList" Spacing="12">
                                        <TextBlock Name="TxtNoDrives"
                                                   Text="{DynamicResource TxtInitialScanNoDrives}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   IsVisible="False"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{DynamicResource TxtInitialScanSources}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>

                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Steam" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglSteam" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <!-- Windows-only sources; visibility set from code-behind -->
                                        <Grid Name="GridEpic" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Epic Games" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEpic" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid Name="GridGOG" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="GOG Galaxy" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglGOG" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid Name="GridXbox" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Xbox (Microsoft Store)" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglXbox" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid Name="GridEA" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="EA App" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEA" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid Name="GridUbisoft" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Ubisoft Connect" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglUbisoft" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Custom Folders -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                                    <TextBlock Grid.Column="0"
                                               Text="{DynamicResource TxtCustomFolders}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource BrTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Name="BtnAddFolder"
                                            Content="{DynamicResource TxtAddFolder}"
                                            Classes="BtnBase"
                                            Padding="12,6"
                                            FontSize="12"
                                            Click="BtnAddFolder_Click"/>
                                </Grid>

                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        MinHeight="80">
                                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Name="PnlCustomFolders" Spacing="8">
                                            <TextBlock Name="TxtNoCustomFolders"
                                                       Text="{DynamicResource TxtNoCustomFolders}"
                                                       Foreground="{StaticResource BrTextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,12"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                </StackPanel> <!-- /PnlScanOptions -->

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Buttons -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0"
                                Padding="24,16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Content="{DynamicResource TxtInitialScanClose}"
                                        Classes="BtnSecondary"
                                        Padding="20,10"
                                        Click="BtnClose_Click"/>
                                <Button Name="BtnStartScan"
                                        Content="{DynamicResource TxtInitialScanStart}"
                                        Classes="BtnPrimary"
                                        Padding="20,10"
                                        Click="BtnStartScan_Click"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>
