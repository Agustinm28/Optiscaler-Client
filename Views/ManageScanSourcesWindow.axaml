<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.ManageScanSourcesWindow"
        Title="Manage Scan Sources"
        Width="640"
        Height="820"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">
            
            <Grid>
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">
                    
                    <Grid RowDefinitions="Auto, *, Auto">
                        
                        <!-- Title Bar -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource TxtManageScanSources}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrTextPrimary}"/>
                                <TextBlock Text="{DynamicResource TxtManageScanSourcesDesc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="24,20">
                                
                                <!-- Default Sources -->
                                <TextBlock Text="{DynamicResource TxtDefaultSources}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>
                                
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        Margin="0,0,0,24">
                                    <StackPanel Spacing="12">
                                        
                                        <!-- Steam -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Steam" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglSteam" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        
                                        <!-- Epic Games -->
                                        <Grid Name="GridEpic" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Epic Games" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEpic" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>

                                        <!-- GOG Galaxy -->
                                        <Grid Name="GridGOG" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="GOG Galaxy" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglGOG" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>

                                        <!-- Xbox (Microsoft Store) -->
                                        <Grid Name="GridXbox" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Xbox (Microsoft Store)" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglXbox" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>

                                        <!-- EA App -->
                                        <Grid Name="GridEA" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="EA App" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEA" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>

                                        <!-- Ubisoft Connect -->
                                        <Grid Name="GridUbisoft" ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Ubisoft Connect" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglUbisoft" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        
                                    </StackPanel>
                                </Border>

                                <!-- Filter Options -->
                                <TextBlock Text="{DynamicResource TxtFilterOptions}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>

                                <StackPanel Spacing="8" Margin="0,0,0,24">

                                    <!-- Option 1: Show All -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,12">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterShowAll"
                                                         GroupName="UpscalerFilter"
                                                         IsChecked="True"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{DynamicResource TxtFilterShowAllTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterShowAllDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Option 2: Hide without upscaler -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,12">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterHideWithoutUpscaler"
                                                         GroupName="UpscalerFilter"
                                                         IsChecked="False"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{DynamicResource TxtFilterHideTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterHideDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Option 3: Skip without upscaler -->
                                    <Border Background="{StaticResource BrBgCard}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="14,12">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         Name="RbFilterSkipWithoutUpscaler"
                                                         GroupName="UpscalerFilter"
                                                         IsChecked="False"
                                                         VerticalAlignment="Top"
                                                         Margin="0,2,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <TextBlock Text="{DynamicResource TxtFilterSkipTitle}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource BrTextPrimary}"/>
                                                <TextBlock Text="{DynamicResource TxtFilterSkipDesc}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,3,0,0"/>
                                                <!-- Warning -->
                                                <Border Background="#1AF59E0B"
                                                        BorderBrush="#40F59E0B"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="10,7">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <TextBlock Grid.Column="0" Text="&#xE7BA;"
                                                                   FontFamily="{StaticResource FontIcons}"
                                                                   FontSize="13"
                                                                   Foreground="#F59E0B"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,1,8,0"/>
                                                        <TextBlock Grid.Column="1" Text="{DynamicResource TxtFilterSkipWarning}"
                                                                   Foreground="#F59E0B"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="{StaticResource FontSizeCaption}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                </StackPanel>

                                <!-- Custom Folders -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                    <TextBlock Grid.Column="0"
                                               Text="{DynamicResource TxtCustomFolders}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource BrTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Name="BtnAddFolder"
                                            Content="{DynamicResource TxtAddFolder}"
                                            Classes="BtnBase"
                                            Padding="12,6"
                                            FontSize="12"
                                            Click="BtnAddFolder_Click"/>
                                </Grid>
                                
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        MinHeight="120">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Name="PnlCustomFolders" Spacing="8">
                                            <!-- Custom folders will be added here dynamically -->
                                            <TextBlock Name="TxtNoCustomFolders"
                                                       Text="{DynamicResource TxtNoCustomFolders}"
                                                       Foreground="{StaticResource BrTextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,20"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Buttons -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0"
                                Padding="24,16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Content="{DynamicResource TxtCancel}"
                                        Classes="BtnSecondary"
                                        Padding="20,10"
                                        Click="BtnCancel_Click"/>
                                <Button Content="{DynamicResource TxtSave}"
                                        Classes="BtnPrimary"
                                        Padding="20,10"
                                        Click="BtnSave_Click"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>
