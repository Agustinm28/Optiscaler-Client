<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.CacheManagementWindow"
        Title="Cache Management"
        Width="500"
        Height="640"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="Ellipse#ImportDot1">
            <Style.Animations>
                <Animation Duration="0:0:0.6" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Margin" Value="4,2,4,10"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse#ImportDot2">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Delay="0:0:0.2" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Margin" Value="4,2,4,10"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse#ImportDot3">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Delay="0:0:0.4" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Margin" Value="4,2,4,10"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Margin" Value="4,12,4,0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">
            
            <Grid>
                <!-- Separate layer for the subtle border -->
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <!-- Main Content Layout -->
                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">
                    
                    <Grid RowDefinitions="Auto, *, Auto">
                        <!-- Custom Title Bar (Draggable) -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource TxtManageCacheTitle}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtManageCacheDesc}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Classes="BtnSecondary"
                                        Padding="8,4"
                                        MinWidth="32"
                                        FontSize="14"
                                        Click="BtnClose_Click"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <!-- List of downloaded versions -->
                        <ScrollViewer Grid.Row="1" Padding="0">
                            <StackPanel Spacing="0" Margin="24,20">
                                <!-- Group 1: OptiScaler -->
                                <TextBlock Text="OptiScaler Versions" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,0,0,12"/>
                                <StackPanel Name="PnlVersions" Spacing="8" Margin="0,0,0,24">
                                    <!-- OptiScaler versions go here -->
                                </StackPanel>

                                <!-- Group 2: Custom OptiScaler Versions -->
                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
                                    <TextBlock Grid.Column="0"
                                               Text="{DynamicResource TxtCustomVersions}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Name="TxtImportStatus"
                                               FontSize="11"
                                               Foreground="{StaticResource BrAccent}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <Button Grid.Column="2"
                                            Name="BtnImportCustom"
                                            Content="{DynamicResource TxtImportArchive}"
                                            Classes="BtnBase"
                                            Padding="12,5"
                                            FontSize="11"
                                            Click="BtnImportCustom_Click"/>
                                </Grid>

                                <!-- Warning banner -->
                                <Border Background="#1AFF9800"
                                        BorderBrush="#FF9800"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource TxtCustomVersionWarning}"
                                               Foreground="#FF9800"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <StackPanel Name="PnlCustomVersions" Spacing="8" Margin="0,0,0,24">
                                    <!-- Custom versions go here -->
                                </StackPanel>

                                <!-- Group 3: FSR 4 INT8 Extras -->
                                <TextBlock Text="FSR4 INT8 (Injection DLLs)" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,0,0,12"/>
                                <StackPanel Name="PnlExtrasVersions" Spacing="8">
                                    <!-- Extras versions go here -->
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2"
                                Padding="24,18"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" 
                                           Name="TxtCacheInfo"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{StaticResource BrTextSecondary}"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource TxtClose}"
                                        Classes="BtnPrimary"
                                        Padding="20,8"
                                        Click="BtnClose_Click"/>
                            </Grid>
                        </Border>

                        <!-- Importing overlay -->
                        <Grid Name="OverlayImporting"
                              Grid.RowSpan="3"
                              Background="#CC000000"
                              IsVisible="False"
                              ZIndex="100">
                            <Border Background="{StaticResource BrBgElevated}"
                                    BorderBrush="{StaticResource BrAccent}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusLarge}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="60,44">
                                <StackPanel HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                        <Ellipse Name="ImportDot1" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                                        <Ellipse Name="ImportDot2" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                                        <Ellipse Name="ImportDot3" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{DynamicResource TxtImporting}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>
